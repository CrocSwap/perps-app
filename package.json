{
    "name": "perps-app-monorepo",
    "version": "0.0.12",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "pnpm i && pnpm prepare && pnpm update-submodules && pnpm --filter frontend dev",
        "prod": "pnpm i && pnpm prepare && pnpm update-submodules && pnpm --filter frontend prod",
        "prepare": "husky",
        "prettier": "prettier --write .",
        "update-submodules": "git submodule update --remote --recursive --merge"
    },
    "lint-staged": {
        "**/*": "prettier --write --ignore-unknown"
    },
    "devDependencies": {
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.1"
    },
    "pnpm": {
        "overrides": {
            "lodash": "4.17.23",
            "bn.js": "5.2.3",
            "serialize-javascript": "7.0.3",
            "axios": "!1.14.1 !0.30.4"
        }
    }
}
